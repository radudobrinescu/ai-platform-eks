#!/usr/bin/env bash
# platformctl — the single entry point for operating the AI platform.
#
# A thin, unified front door over `make` + Terraform + the helpers in ops/lib/.
# It removes the "which command in what order" friction; it is NOT a bespoke
# provisioning engine — every verb shells out to tools that already exist.
#
# Usage:
#   ./platformctl up      [ENV]        Provision everything (state backend + all Terraform stages)
#   ./platformctl status  [--check]    Show health + where the UIs are reachable; --check validates end-to-end
#   ./platformctl tunnel               Reach the private UIs locally (SSM port-forward to the ClusterIPs)
#   ./platformctl edge    [MODE] [ENV] Choose the public front door: cloudfront | domain | tunnel
#   ./platformctl new-model MODEL [..] Right-size a model + scaffold its serving YAML (VLLMEndpoint/LLMDEndpoint)
#   ./platformctl down    [ENV]        Tear everything down (asks to confirm)
#   ./platformctl list-envs            List the configured environments (marks the active default)
#
# ENV is resolved in this order and NEVER guessed: explicit arg > $PLATFORM_ENV >
# the deployed Terraform workspace of the cluster stage. Region comes from
# $AWS_REGION / your AWS config.
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TF_DIR="${REPO_ROOT}/terraform"
LIB_DIR="${REPO_ROOT}/ops/lib"
CLUSTER_STAGE="30.eks/30.cluster"
NS_PLATFORM="ai-platform"

# UI -> local tunnel port (matches ops/lib/tunnel.sh and the ALB listener ports).
UI_PORTS=("Open WebUI:8080" "LiteLLM:4000" "Langfuse:3000" "Dashboard:9090")

c_bold=$'\033[1m'; c_dim=$'\033[2m'; c_grn=$'\033[32m'; c_red=$'\033[31m'; c_ylw=$'\033[33m'; c_rst=$'\033[0m'
[ -t 1 ] || { c_bold=""; c_dim=""; c_grn=""; c_red=""; c_ylw=""; c_rst=""; }

log()  { echo "${c_bold}==>${c_rst} $*"; }
ok()   { echo "${c_grn}✓${c_rst} $*"; }
warn() { echo "${c_ylw}!${c_rst} $*" >&2; }
die()  { echo "${c_red}✗${c_rst} $*" >&2; exit 1; }
need() { command -v "$1" >/dev/null 2>&1 || die "missing required tool: $1"; }

# Print the leading comment block as usage.
usage() { sed -n '2,/^[^#]/p' "${BASH_SOURCE[0]}" | grep '^#' | sed 's/^# \{0,1\}//'; }

require_tfvars() {
  local env="$1" f="${TF_DIR}/00.global/vars/${1}.tfvars"
  [ -f "$f" ] || die "no tfvars for env '${env}': ${f}
  Copy 00.global/vars/example.tfvars and set your Identity Center ARN + gitops_repo_url."
}

# Resolve the target env WITHOUT ever guessing (guessing 'dev' would point
# Terraform at the wrong/empty workspace). Order: explicit arg > $PLATFORM_ENV >
# the cluster stage's selected Terraform workspace. Empty string => unresolved.
resolve_env() {
  local explicit="${1:-}"
  if [ -n "$explicit" ]; then echo "$explicit"; return 0; fi
  if [ -n "${PLATFORM_ENV:-}" ]; then echo "$PLATFORM_ENV"; return 0; fi
  local ws
  ws=$(cat "${TF_DIR}/${CLUSTER_STAGE}/.terraform/environment" 2>/dev/null || true)
  [ -n "$ws" ] && [ "$ws" != "default" ] && { echo "$ws"; return 0; }
  return 1
}

need_env() {
  local env; env=$(resolve_env "${1:-}") || die "cannot determine the environment.
  Pass it explicitly (e.g. '$2 <env>') or set PLATFORM_ENV=<env>."
  echo "$env"
}

# True if a TCP listener is up on localhost:<port> (detects an active tunnel).
port_open() { (exec 3<>"/dev/tcp/127.0.0.1/$1") 2>/dev/null; }

# Print the live CloudFront edge URLs (empty if none), env-agnostic — reads the
# real distributions so it reflects what's actually deployed, not just config.
edge_urls_live() {
  aws cloudfront list-distributions \
    --query "DistributionList.Items[?starts_with(Comment,'ai-platform ')].[Comment,DomainName,Status]" \
    --output text 2>/dev/null \
    | awk -F'\t' 'NF{sub(/^ai-platform /,"",$1); printf "    %-11s https://%s  [%s]\n",$1,$2,$3}'
}

# ---- up / down ------------------------------------------------------------- #

cmd_up() {
  local env; env=$(need_env "${1:-}" "up")
  need terraform; need aws; need make; require_tfvars "$env"
  log "Provisioning '${env}' — EKS + capabilities + Karpenter (takes a while)"
  make -C "$TF_DIR" bootstrap ENVIRONMENT="$env"
  make -C "$TF_DIR" apply-all ENVIRONMENT="$env"
  echo
  ok "Done. Next:"
  echo "  ./platformctl status --check     # confirm it's healthy AND working"
  echo "  ./platformctl tunnel             # reach the UIs locally"
  echo "  ./platformctl edge               # (optional) choose a public front door"
}

cmd_down() {
  local env; env=$(need_env "${1:-}" "down")
  need terraform; need make; require_tfvars "$env"
  warn "This DESTROYS all infrastructure for env '${env}'."
  read -r -p "Type the environment name ('${env}') to confirm: " confirm
  [ "$confirm" = "$env" ] || die "confirmation mismatch — aborted (nothing changed)."
  make -C "$TF_DIR" destroy-all ENVIRONMENT="$env"
}

# ---- status [--check] ------------------------------------------------------ #

cmd_status() {
  need kubectl
  local deep=0
  [ "${1:-}" = "--check" ] && deep=1

  log "ArgoCD applications"
  kubectl get applications -n argocd 2>/dev/null \
    || warn "cannot reach the cluster — run: aws eks update-kubeconfig --name <cluster>"
  echo
  log "Platform pods (${NS_PLATFORM})"
  kubectl get pods -n "$NS_PLATFORM" 2>/dev/null || true
  echo
  log "Serving endpoints (all namespaces)"
  kubectl get vllmendpoints,llmdendpoints,llmddisaggendpoints -A 2>/dev/null || echo "  (none deployed)"

  echo
  _status_access

  [ "$deep" -eq 1 ] || { echo; echo "${c_dim}Run 'platformctl status --check' to validate Bedrock + gateway + tracing.${c_rst}"; return; }
  echo
  _status_check
}

# Where are the UIs reachable? Shows the edge posture, live public URLs, and
# whether a local tunnel is currently up.
_status_access() {
  log "Access — where the UIs are reachable"
  local shown=0

  # 1) CloudFront edge (public HTTPS). Read the live distributions.
  local cf=""
  command -v aws >/dev/null 2>&1 && cf=$(edge_urls_live || true)
  if [ -n "$cf" ]; then
    echo "  ${c_grn}CloudFront edge${c_rst} (public HTTPS; [Deployed] = live, [InProgress] = still rolling out):"
    echo "$cf"
    shown=1
  fi

  # 2) Own-domain posture: the ALB is internet-facing.
  local scheme
  scheme=$(kubectl get ingress -n "$NS_PLATFORM" -o jsonpath='{.items[0].metadata.annotations.alb\.ingress\.kubernetes\.io/scheme}' 2>/dev/null || true)
  if [ "$scheme" = "internet-facing" ]; then
    local albhost
    albhost=$(kubectl get ingress -n "$NS_PLATFORM" -o jsonpath='{.items[0].status.loadBalancer.ingress[0].hostname}' 2>/dev/null || true)
    echo "  ${c_grn}Internet-facing ALB${c_rst} — reach the UIs at your DNS names (or ${albhost:-the ALB host}) on ports 8080/4000/3000/9090."
    shown=1
  fi

  # 3) Local tunnel: is one currently running?
  local any_up=0 pair name port line=""
  for pair in "${UI_PORTS[@]}"; do
    name="${pair%%:*}"; port="${pair##*:}"
    if port_open "$port"; then any_up=1; line="${line}    ${name}: http://localhost:${port}\n"; fi
  done
  if [ "$any_up" -eq 1 ]; then
    echo "  ${c_grn}Tunnel ACTIVE${c_rst} (this machine):"
    printf "%b" "$line"
    shown=1
  else
    echo "  ${c_dim}No tunnel running on this machine — start one: ./platformctl tunnel${c_rst}"
  fi

  # 4) Nothing public + internal ALB: make the private posture explicit.
  if [ "$shown" -eq 0 ] && [ "$scheme" != "internet-facing" ]; then
    echo "  ${c_dim}UIs are private (internal ALB). Go public with ./platformctl edge cloudfront, or tunnel above.${c_rst}"
  fi
}

# Active end-to-end validation (--check).
_status_check() {
  log "Validating the platform end-to-end (--check)"
  need aws
  local mk code base="http://127.0.0.1:4000" pf_pid=""
  mk=$(kubectl get secret litellm-secrets -n "$NS_PLATFORM" -o jsonpath='{.data.master-key}' 2>/dev/null | base64 -d) \
    || { warn "cannot read litellm master key — is the platform up?"; return 1; }
  kubectl port-forward -n "$NS_PLATFORM" svc/litellm 4000:4000 >/dev/null 2>&1 &
  pf_pid=$!
  sleep 4

  if curl -fsS "$base/v1/models" -H "Authorization: Bearer $mk" >/dev/null 2>&1; then
    ok "LiteLLM gateway responding (/v1/models)"
  else
    warn "LiteLLM gateway not responding"
  fi
  code=$(curl -s -o /dev/null -w '%{http_code}' -X POST "$base/v1/chat/completions" \
    -H "Authorization: Bearer $mk" -H "Content-Type: application/json" \
    -d '{"model":"claude-opus-4-8","messages":[{"role":"user","content":"ping"}],"max_tokens":5}')
  if [ "$code" = "200" ]; then
    ok "Bedrock frontier model answered (claude-opus-4-8)"
  else
    warn "Bedrock model call returned HTTP $code — enable Bedrock model access in the console (per-account toggle)"
  fi
  if kubectl run pfcheck-langfuse --rm -i --restart=Never --image=curlimages/curl:8.11.0 -n "$NS_PLATFORM" --quiet -- \
       -fsS http://langfuse-web.ai-platform.svc.cluster.local:3000/api/public/health >/dev/null 2>&1; then
    ok "Langfuse tracing reachable"
  else
    warn "Langfuse health check failed (tracing may be starting)"
  fi

  [ -n "${pf_pid:-}" ] && kill "$pf_pid" 2>/dev/null || true
}

# ---- tunnel ---------------------------------------------------------------- #

cmd_tunnel() { exec "${LIB_DIR}/tunnel.sh"; }

# ---- edge ------------------------------------------------------------------ #

cmd_edge() {
  local mode="${1:-}"
  case "$mode" in
    cloudfront) _edge_apply cloudfront "${2:-}" ;;
    tunnel|off) _edge_apply off "${2:-}" ;;
    domain)     _edge_domain_help ;;
    ""|status)  _edge_help ;;
    *) die "unknown edge mode: ${mode}  (use: cloudfront | domain | tunnel)" ;;
  esac
}

# Enable/disable the CloudFront edge. Guarded three ways: (1) env is resolved,
# never guessed; (2) a typed confirmation showing the exact env; (3) the real
# Terraform plan is shown and a second 'yes' is required before anything applies.
# Everything runs through the Makefile so the workspace, var-file, and backend
# are always the deployed env's (the cause of the earlier "53 to add" was a
# guessed 'dev' env pointing at an empty workspace — now impossible).
_edge_apply() {
  local action="$1" env
  need terraform; need make; need aws
  env=$(need_env "${2:-}" "edge ${action/off/tunnel}")
  require_tfvars "$env"
  local want; [ "$action" = cloudfront ] && want=true || want=false

  echo
  if [ "$action" = cloudfront ]; then
    warn "About to ENABLE the CloudFront edge — a significant, user-facing change:"
    echo "    • creates 4 public CloudFront distributions (BILLABLE) fronting the private ALB"
    echo "    • exposes Open WebUI / LiteLLM / Langfuse / Dashboard on public *.cloudfront.net HTTPS"
    echo "    • rewrites the Cognito OIDC callback URLs to those public domains"
  else
    warn "About to DISABLE the CloudFront edge — a significant, user-facing change:"
    echo "    • DESTROYS the 4 CloudFront distributions + VPC origins (public URLs stop working)"
    echo "    • reverts the Cognito callbacks; reach the UIs via ./platformctl tunnel afterwards"
  fi
  echo "    Environment: ${c_bold}${env}${c_rst}   (Terraform workspace: ${env})"
  echo
  read -r -p "Type the environment name ('${env}') to continue to the plan: " confirm
  [ "$confirm" = "$env" ] || die "confirmation mismatch — aborted (nothing changed)."

  _edge_set_tfvar "$env" "$want"
  echo; log "Planning the change for '${env}' — review the plan below carefully:"
  make -C "$TF_DIR" plan MODULE="$CLUSTER_STAGE" ENVIRONMENT="$env"
  echo
  read -r -p "Apply the plan above to '${env}'? Type 'yes' to proceed (anything else aborts): " go
  [ "$go" = "yes" ] || die "aborted at plan review (nothing applied)."
  make -C "$TF_DIR" apply MODULE="$CLUSTER_STAGE" ENVIRONMENT="$env"

  # The apps read their public URL from a Secret/ConfigMap at startup (OIDC
  # redirects) and the dashboard reads the edge URLs from a ConfigMap env — none
  # hot-reload, so restart them to pick up the new URLs. Best-effort.
  if command -v kubectl >/dev/null 2>&1; then
    log "Restarting the UIs + dashboard to pick up the new URLs…"
    kubectl rollout restart deployment -n "$NS_PLATFORM" \
      open-webui litellm langfuse-web oauth2-proxy cluster-dashboard >/dev/null 2>&1 \
      || warn "could not restart some deployments — restart them manually to apply the new URLs"
  fi

  echo
  if [ "$action" = cloudfront ]; then
    ok "CloudFront edge applied for '${env}'. Public URLs ([InProgress] until ~10-15 min out):"
    edge_urls_live
    echo "${c_dim}Cognito callbacks + the dashboard Quick Links were updated automatically. Track rollout with: ./platformctl status${c_rst}"
  else
    ok "CloudFront edge removed for '${env}'. Reach the UIs with: ./platformctl tunnel"
  fi
}

_edge_domain_help() {
  cat <<EOF
${c_bold}Front door: your own domain on an internet-facing ALB${c_rst}
This is a GitOps change (the ALB scheme + cert live in the ingress manifests),
so edit + commit + push in your fork — there is no Terraform toggle:
  1. In platform/config/ingress.yaml (x3) + platform/services/cluster-dashboard/manifests.yaml,
     set on all four ingresses:
       alb.ingress.kubernetes.io/scheme: internet-facing
       alb.ingress.kubernetes.io/listen-ports: '[{"HTTPS": <port>}]'
       alb.ingress.kubernetes.io/certificate-arn: <your ACM cert ARN, in this region>
     and set inbound-cidrs to your own IP/CIDR ranges (never 0.0.0.0/0).
  2. Point your DNS (Route53 alias / CNAME) at the ALB hostname.
  3. Put your domain URLs in sso_public_urls in your tfvars and re-apply the
     cluster stage to wire the Cognito callbacks (a normal 'up' does this).
EOF
}

_edge_help() {
  cat <<EOF
${c_bold}Public front door — three postures:${c_rst}
  ${c_grn}tunnel${c_rst}      Private ALB, no public IP. Reach the UIs via ./platformctl tunnel. (default)
  ${c_grn}cloudfront${c_rst}  Public HTTPS via CloudFront VPC origins to the private ALB — free
              *.cloudfront.net cert, no domain needed. Good for demo/PoC. BILLABLE.
              Run AFTER 'up' (needs the ALB):  ./platformctl edge cloudfront [ENV]
  ${c_grn}domain${c_rst}      Your own domain + cert on an internet-facing ALB (enterprise).
              Guided GitOps change:            ./platformctl edge domain

  Turn CloudFront off (destroys the distributions):  ./platformctl edge tunnel [ENV]
  See the current posture + URLs any time:           ./platformctl status
EOF
}

# Set enable_cloudfront_edge in the env tfvars (durable), adding the line if absent.
_edge_set_tfvar() {
  local env="$1" val="$2" f="${TF_DIR}/00.global/vars/${1}.tfvars"
  if grep -q '^enable_cloudfront_edge' "$f"; then
    sed -i.bak "s/^enable_cloudfront_edge.*/enable_cloudfront_edge = ${val}/" "$f" && rm -f "${f}.bak"
  else
    printf '\nenable_cloudfront_edge = %s\n' "$val" >> "$f"
  fi
}

# ---- new-model ------------------------------------------------------------- #

cmd_new_model() {
  need python3
  [ "$#" -ge 1 ] || die "usage: platformctl new-model <hf-model-id> [flags]
  e.g. platformctl new-model Qwen/Qwen2.5-3B-Instruct --seq 8192 --users 4"
  exec python3 "${LIB_DIR}/recommend-instance.py" "$@"
}

# ---- list-envs ------------------------------------------------------------- #

# List the configured environments (one per 00.global/vars/<env>.tfvars, minus
# the example templates) and highlight the one the other verbs resolve to when
# [ENV] is omitted. Reads only local files — no cluster/AWS access needed.
cmd_list_envs() {
  local vars_dir="${TF_DIR}/00.global/vars" active found=0 f env
  active=$(resolve_env "" 2>/dev/null || true)

  log "Environments (${vars_dir#"$REPO_ROOT"/}/<env>.tfvars)"
  for f in "$vars_dir"/*.tfvars; do
    [ -e "$f" ] || continue
    env="$(basename "$f" .tfvars)"
    case "$env" in example|example-*) continue ;; esac
    found=1
    if [ "$env" = "$active" ]; then
      echo "  ${c_grn}● ${env}${c_rst}  ${c_dim}(active)${c_rst}"
    else
      echo "    ${env}"
    fi
  done
  [ "$found" -eq 1 ] || warn "no environments configured yet — copy ${vars_dir#"$REPO_ROOT"/}/example.tfvars to <env>.tfvars"

  echo
  if [ -n "$active" ]; then
    local src; [ -n "${PLATFORM_ENV:-}" ] && src="\$PLATFORM_ENV" || src="the deployed Terraform workspace"
    echo "${c_dim}'${active}' (from ${src}) is used when a verb's [ENV] is omitted; override with an explicit arg or PLATFORM_ENV.${c_rst}"
  else
    echo "${c_dim}No active env resolved — pass [ENV] explicitly or set PLATFORM_ENV=<env>.${c_rst}"
  fi
}

# ---- dispatch -------------------------------------------------------------- #

main() {
  local cmd="${1:-}"; shift || true
  case "$cmd" in
    up)        cmd_up "$@" ;;
    down)      cmd_down "$@" ;;
    status)    cmd_status "$@" ;;
    tunnel)    cmd_tunnel "$@" ;;
    edge)      cmd_edge "$@" ;;
    new-model) cmd_new_model "$@" ;;
    list-envs|envs) cmd_list_envs "$@" ;;
    ""|-h|--help|help) usage ;;
    *) die "unknown command: ${cmd}
$(usage)" ;;
  esac
}

main "$@"
